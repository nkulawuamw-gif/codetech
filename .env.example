# Supabase configuration
# Copy this file to `.env.local` and fill in your project credentials.
# Get them from https://app.supabase.com → Project Settings → API
#
# When these are set, the app fetches content from the database.
# When they are missing, the app uses the local data in src/data/content.js
# so it still works out of the box.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key-here
